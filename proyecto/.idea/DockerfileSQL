# Use a JDK image that can both build and run the app
FROM openjdk:17-jdk-slim

# Set the working directory
WORKDIR /app

# Copy the entire project into the container
COPY .. .

# Build the application (creates a "fat JAR")
# -x test skips tests to speed up the container build
RUN ./gradlew build -x test

# Expose the default Ktor port
EXPOSE 8080

# Run the application
# Replace 'myapp-all.jar' with the actual name generated in build/libs/
CMD ["java", "-jar", "build/libs/myapp-all.jar"]
